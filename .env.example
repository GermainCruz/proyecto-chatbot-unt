# ============================================================
# UNT Bot — variables de entorno
# Copia este archivo como .env y ajusta los valores.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=untbot
POSTGRES_PASSWORD=untbot
POSTGRES_DB=untbot

# ---- Backend (FastAPI) ----
JWT_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria
CORS_ORIGINS=http://localhost:3000

# Modelo LLM y embeddings (OpenAI)
# Si dejas OPENAI_API_KEY vacío, el sistema funciona en MODO DEMO
# (respuestas heurísticas). Para calidad real, configura tu API key.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Administrador inicial (se crea automáticamente al iniciar)
ADMIN_EMAIL=admin@unitru.edu.pe
ADMIN_PASSWORD=Admin1234*
ADMIN_NAME=Administrador UNT Bot

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api
